generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  role     String

  products Product[]
}

model Product {
  id        String   @id @default(uuid())
  name      String
  sku       String
  price     Float
  quantity  Int
  category  String
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])
}