generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Added User Model
model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  role      String    @default("user")
  createdAt DateTime  @default(now())
  
  // Relation field: A user can have many products
  products  Product[]
}

// 2. Updated Product Model
model Product {
  id        String   @id @default(uuid())
  name      String
  sku       String
  price     Float
  quantity  Int
  category  String
  createdAt DateTime @default(now())

  // Relation fields: Connects each product to a specific user
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}